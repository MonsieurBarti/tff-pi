{
	"name": "@the-forge-flow/tff-pi",
	"version": "0.1.1",
	"description": "TFF PI",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json && cp -r src/resources dist/resources",
		"dev": "tsc -p tsconfig.build.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"fmt": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"prepare": "lefthook install || true"
	},
	"keywords": [
		"pi",
		"pi-coding-agent",
		"extension",
		"tff",
		"the-forge-flow"
	],
	"author": "The Forge Flow",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/MonsieurBarti/tff-pi.git"
	},
	"bugs": {
		"url": "https://github.com/MonsieurBarti/tff-pi/issues"
	},
	"homepage": "https://github.com/MonsieurBarti/tff-pi#readme",
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-tui": "*",
		"@sinclair/typebox": "*",
		"@the-forge-flow/fff-pi": "*",
		"@the-forge-flow/gh-pi": "*",
		"@the-forge-flow/gitnexus-pi": "*",
		"@the-forge-flow/lightpanda-pi": "*",
		"@the-forge-flow/hippo-memory-pi": "*",
		"@the-forge-flow/sub-agents-pi": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@commitlint/cli": "^19.8.0",
		"@commitlint/config-conventional": "^19.8.0",
		"@mariozechner/pi-ai": "^0.66.1",
		"@mariozechner/pi-coding-agent": "^0.66.1",
		"@mariozechner/pi-tui": "^0.66.1",
		"@sinclair/typebox": "^0.34.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^2.1.0",
		"lefthook": "^2.1.5",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	},
	"dependencies": {
		"better-sqlite3": "^12.8.0",
		"yaml": "^2.8.3"
	}
}
